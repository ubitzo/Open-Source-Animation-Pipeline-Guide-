{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Set Up","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"toc-heading","version":1,"tag":"h1","id":"set-up"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"Here is a basic set up of Storyboard Pro. It has an infinite canvas which helps with planning camera moves. For this we will be focusing on how to draw in 3D for this scene.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""},{"altText":"","caption":{"editorState":{"root":{"children":[],"direction":null,"format":"","indent":0,"type":"root","version":1}}},"showCaption":false,"showBorder":true,"src":"_images/Screenshot 2026-04-06 at 3.06.44 PM.png","type":"image","version":1,"width":"100%","align":"center"},{"calloutType":"note","content":{"editorState":{"root":{"children":[{"children":[{"detail":0,"format":1,"mode":"normal","style":"","text":"Note: Storyboard Pro 3D workflow/load","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1,"textStyle":""},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"A file can become really heavy if you have a lot of drawn 3D layers. If you have a 3D model you can use for your scene this will probably much lighter on the program.(I have not tried inserting 3D models directly into Storyboard Pro yet and the guide will be updated when it is) It is based on if you want to mock up or 3D or 2D first. ","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0,"textStyle":""}],"direction":null,"format":"","indent":0,"type":"root","version":1}}},"type":"callout-box","version":1},{"children":[{"detail":0,"format":0,"mode":"normal","style":"","text":"First set up the windows that will be needed for a 3D scene:","type":"text","version":